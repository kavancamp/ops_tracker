<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "OpsTracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= yield :head %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "OpsTracker", root_path, class: "navbar-brand" %>

        <div class="d-flex gap-2">
          <%= link_to "Locations", locations_path, class: "btn btn-outline-light btn-sm" %>
          <%= link_to "Assets", assets_path, class: "btn btn-outline-light btn-sm" %>
          <%= link_to "New Location", new_location_path, class: "btn btn-primary btn-sm" %>
          <%= link_to "New Asset", new_asset_path, class: "btn btn-success btn-sm" %>
        </div>
      </div>
    </nav>

    <div class="container">
      <%= yield %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>