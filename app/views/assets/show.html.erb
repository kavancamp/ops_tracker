<div class="container mt-4">
  <h1><%= @asset.name %></h1>

  <div class="card mt-3">
    <div class="card-body">
      <p><strong>Type:</strong> <%= @asset.asset_type %></p>
      <p><strong>Serial Number:</strong> <%= @asset.serial_number %></p>
      <p><strong>Status:</strong> <%= @asset.status %></p>
      <p><strong>Location:</strong> <%= @asset.location.name %></p>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <%= link_to "Edit Asset", edit_asset_path(@asset), class: "btn btn-outline-secondary" %>
    <%= link_to "Add Maintenance Record", new_asset_maintenance_record_path(@asset), class: "btn btn-primary" %>
    <%= link_to "Back to Assets", assets_path, class: "btn btn-outline-primary" %>
  </div>

  <hr class="my-4">

  <h3>Maintenance History</h3>

  <% if @asset.maintenance_records.any? %>
    <div class="list-group mt-3">
      <% @maintenance_records.each do |record| %>
        <div class="list-group-item">
          <div class="d-flex justify-content-between">
            <strong><%= record.vendor %></strong>
            <span><%= record.performed_at.strftime("%Y-%m-%d %H:%M") %></span>
          </div>
          <div class="mt-2">
            <p class="mb-1"><strong>Cost:</strong> $<%= record.cost %></p>
            <p class="mb-0"><strong>Notes:</strong> <%= record.notes %></p>
          </div>
        </div>
      <% end %> 
      <div class="mt-3d-flex justify-content-center mt-1">
        <%= paginate @maintenance_records %>
      </div>
    </div>
  <% else %>
    <p class="text-muted mt-3">No maintenance records yet.</p>
  <% end %>
</div> 