<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Assets</h1>
    <%= link_to "New Asset", new_asset_path, class: "btn btn-primary" %>
  </div>

<div class="card mb-4">
  <div class="card-body">
    <%= form_with url: assets_path, method: :get, local: true, class: "row g-2" do |f| %>

      <div class="col-md-3">
        <%= f.label :query, "Search", class: "form-label" %>
        <%= f.text_field :query, value: params[:query], class: "form-control", placeholder: "Search assets..." %>
      </div>

      <div class="col-md-3">
        <%= f.label :status, class: "form-label" %>
        <%= f.select :status,
            options_for_select(Asset::VALID_STATUSES, params[:status]),
            { prompt: "All statuses" },
            class: "form-select" %>
      </div>

      <div class="col-md-3">
        <%= f.label :location_id, "Location", class: "form-label" %>
        <%= f.select :location_id,
            options_from_collection_for_select(@locations, :id, :name, params[:location_id]),
            { prompt: "All locations" },
            class: "form-select" %>
      </div>

      <div class="col-md-2 d-flex align-items-end">
        <%= f.submit "Search", class: "btn btn-primary w-100" %>
      </div>
      <div class="col-md-2 d-flex  align-items-end">
        <%= link_to "Clear", assets_path, class: "btn btn-outline-secondary w-100" %>
      </div>
    <% end %>
  </div>
</div>

  <% if @assets.any? %>
    <div class="row">
      <% @assets.each do |asset| %>
        <div class="col-md-6 col-lg-4 mb-3"> 

          <div class="card h-100"> 
            <div class="card-body">  
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title mb-0"><%= asset.name %></h5>
                <% if asset.needs_attention? %>
                  <span class="badge bg-danger">Needs Attention</span>
                <% end %>
              </div>            
            </div>
              <p class="card-text mb-1"><strong>Type:</strong> <%= asset.asset_type %></p>
              <p class="card-text mb-1"><strong>Status:</strong> <%= asset.status %></p>
              <p class="card-text text-muted"><strong>Location:</strong> <%= asset.location.name %></p>
              <div class="d-flex gap-2">
                <%= link_to "View", asset_path(asset), class: "btn btn-outline-primary btn-sm" %>
                <%= link_to "Edit", edit_asset_path(asset), class: "btn btn-outline-secondary btn-sm" %>
              </div>   
          </div>
       
        </div>
      <% end %>
      <div class="mt-3 d-flex justify-content-center">
        <%= paginate @assets, params: request.query_parameters %>
    </div>
  <% else %>
    <p>No assets yet.</p>
  <% end %>
</div>