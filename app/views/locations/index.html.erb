<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Locations</h1>
    <%= link_to "New Location", new_location_path, class: "btn btn-primary" %>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <%= form_with url: locations_path, method: :get, local: true, class: "row g-2" do |f| %>
        <div class="col-md-8">
          <%= f.label :query, "Search locations", class: "form-label" %>
          <%= f.text_field :query,
              value: params[:query],
              class: "form-control",
              placeholder: "Search by location name or region..." %>
        </div>

        <div class="col-md-2 d-flex align-items-end">
          <%= f.submit "Search", class: "btn btn-primary w-100" %>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <%= link_to "Clear", locations_path, class: "btn btn-outline-secondary w-100" %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @locations.any? %>
    <div class="row">
      <% @locations.each do |location| %>
        <div class="col-md-6 col-lg-4 mb-3">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title"><%= location.name %></h5>
              <p class="card-text text-muted"><%= location.region %></p>
              <div class="d-flex gap-2">
                <%= link_to "View", location_path(location), class: "btn btn-outline-primary btn-sm" %>
                <%= link_to "Edit", edit_location_path(location), class: "btn btn-outline-secondary btn-sm" %>
              </div>
            </div>        
          <div class="mt-3 d-flex justify-content-center">
            <%= paginate @locations, params: request.query_parameters %>
          </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p>No locations yet.</p>
  <% end %>
</div>