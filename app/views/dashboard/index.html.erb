<div class="container mt-4">
  <h1>Dashboard</h1>

  <div class="row mt-3">
    <div class="col-md-3">
      <div class="card text-white bg-primary mb-3">
        <div class="card-body">
          <h5 class="card-title">Total Locations</h5>
          <p class="card-text display-4"><%= @locations_count %></p>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card text-white bg-success mb-3">
        <div class="card-body">
          <h5 class="card-title">Total Assets</h5>
          <p class="card-text display-4"><%= @assets_count %></p>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card text-white bg-info mb-3">
        <div class="card-body">
          <h5 class="card-title">Active Assets</h5>
          <p class="card-text display-4"><%= @active_assets_count %></p>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card text-white bg-warning mb-3">
        <div class="card-body">
          <h5 class="card-title">Maintenance Assets</h5>
          <p class="card-text display-4"><%= @maintenance_assets_count %></p>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card text-white bg-secondary mb-3">
        <div class="card-body">
          <h5 class="card-title">Retired Assets</h5>
          <p class="card-text display-4"><%= @retired_assets_count %></p>
        </div>
      </div>
    </div>
  </div>
</div>

<hr class="my-4">

<h3>Assets Needing Attention</h3>

<% if @attention_assets.any? %>
  <div class="list-group mt-3">
    <% @attention_assets.each do |asset| %>
      <div class="list-group-item d-flex justify-content-between align-items-center">
        <div>
          <strong><%= asset.name %></strong>
            <% if asset.needs_attention? %>
              <span class="badge bg-danger">Needs Attention</span>
            <% end %>
          <div class="text-muted">
            <%= asset.location.name %> • <%= asset.asset_type %>
          </div>
        </div>

        <%= link_to "View", asset_path(asset), class: "btn btn-sm btn-outline-primary" %>
      </div>
    <% end %>
  </div>
<% else %>
  <p class="text-muted mt-3">No assets currently need attention.</p>
<% end %>